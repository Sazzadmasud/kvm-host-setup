#!/bin/bash
# Watches all OCP VMs for RHCOS image-write completion and ejects the
# agent ISO from each node before it can reboot back into the installer.
#
# Detection (first signal wins per node):
#   1. virsh domain state goes to shut-off  (post-write reboot)
#   2. install log shows Writing image.*100 or Rebooting for the node

# --- Jinja2-rendered variables ---
LOG="{{ ocp_install_dir }}/.openshift_install.log"
all_vms=({{ all_vm_names | join(' ') }})
timeout={{ eject_timeout_minutes * 60 }}
# ---------------------------------

{% raw %}
COORD_DIR="/tmp/ocp_eject_coord"
mkdir -p "$COORD_DIR"
trap 'rm -rf "$COORD_DIR"' EXIT

elapsed=0

eject_vm() {
    local vm=$1
    # Always config-only — never eject while the VM is running.
    # --live disconnects the ISO from the running guest, which triggers the
    # agent's media-connected validation to fail, putting the host (and the
    # entire cluster) into error state and halting all remaining installs.
    # --config alone removes the ISO source from the persistent XML so that
    # after the post-write reboot UEFI sees an empty CDROM, falls through to
    # boot order 2 (vda), and the node boots into RHCOS. The running agent
    # never observes a disconnect.
    if virsh -c qemu:///system change-media "$vm" sda --eject --config 2>/dev/null; then
        echo "[$(date +%T)] $vm: ISO removed from persistent XML (node will boot from disk on reboot)"
    else
        echo "[$(date +%T)] $vm: WARNING — config eject failed; node may reboot from ISO"
    fi
    touch "$COORD_DIR/$vm"
}

remaining_count() {
    local n=0
    for vm in "${all_vms[@]}"; do
        [[ -f "$COORD_DIR/$vm" ]] || n=$((n + 1))
    done
    echo "$n"
}

total=${#all_vms[@]}
echo "Monitoring $total node(s) for RHCOS image-write completion..."

while [[ $elapsed -lt $timeout ]]; do
    for vm in "${all_vms[@]}"; do
        [[ -f "$COORD_DIR/$vm" ]] && continue

        state=$(virsh -c qemu:///system domstate "$vm" 2>/dev/null | tr -d ' \n')

        case "$state" in
            shutoff|inshutdown)
                echo "[$(date +%T)] $vm is $state — post-write reboot detected"
                eject_vm "$vm"
                ;;
            running)
                if grep -qiE \
                    "Host:[[:space:]]+${vm}[^,]*,.*(Writing image.*100|Rebooting)" \
                    "$LOG" 2>/dev/null; then
                    echo "[$(date +%T)] $vm: image-write complete (log signal)"
                    eject_vm "$vm"
                fi
                ;;
            paused|suspended)
                echo "[$(date +%T)] $vm: unexpected state $state, skipping this cycle"
                ;;
        esac
    done

    if [[ $(remaining_count) -eq 0 ]]; then
        echo "All ISOs ejected successfully."
        exit 0
    fi

    sleep 5
    elapsed=$((elapsed + 5))
done

echo "WARNING: monitor timed out after ${timeout}s — force-ejecting remaining nodes."
for vm in "${all_vms[@]}"; do
    [[ -f "$COORD_DIR/$vm" ]] && continue
    eject_vm "$vm"
done
echo "Force-eject complete."
{% endraw %}
