global
    log stdout format raw local0
    maxconn 20000

defaults
    log     global
    option  tcplog
    option  dontlognull
    retries 3
    timeout connect 10s
    timeout client  1m
    timeout server  1m

#---------------------------------------------------------------------
# API server — port 6443  (bound to API VIP {{ api_vip }})
#---------------------------------------------------------------------
frontend api
    bind {{ api_vip }}:6443
    mode tcp
    default_backend api-backend

backend api-backend
    mode tcp
    balance roundrobin
{% for node in control_nodes %}
    server {{ node.name }} {{ node.ip }}:6443 check
{% endfor %}

#---------------------------------------------------------------------
# Machine Config server — port 22623  (bound to API VIP {{ api_vip }})
#---------------------------------------------------------------------
frontend machine-config
    bind {{ api_vip }}:22623
    mode tcp
    default_backend mc-backend

backend mc-backend
    mode tcp
    balance roundrobin
{% for node in control_nodes %}
    server {{ node.name }} {{ node.ip }}:22623 check
{% endfor %}

#---------------------------------------------------------------------
# Ingress HTTP — port 80  (bound to ingress VIP {{ ingress_vip }})
#---------------------------------------------------------------------
frontend ingress-http
    bind {{ ingress_vip }}:80
    mode tcp
    default_backend ingress-http-backend

backend ingress-http-backend
    mode tcp
    balance roundrobin
{% for node in worker_nodes %}
    server {{ node.name }} {{ node.ip }}:80 check
{% endfor %}

#---------------------------------------------------------------------
# Ingress HTTPS — port 443  (bound to ingress VIP {{ ingress_vip }})
#---------------------------------------------------------------------
frontend ingress-https
    bind {{ ingress_vip }}:443
    mode tcp
    default_backend ingress-https-backend

backend ingress-https-backend
    mode tcp
    balance roundrobin
{% for node in worker_nodes %}
    server {{ node.name }} {{ node.ip }}:443 check
{% endfor %}
